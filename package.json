{
  "name": "carepack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/entry-server.jsx --outDir dist-ssr && node scripts/prerender.js",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.jsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.js",
    "preview": "npx serve dist --listen 4174 --no-request-logging",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "i18next": "^23.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "prettier": "^3.8.1",
    "sass": "^1.77.8",
    "vite": "^5.4.2"
  }
}
